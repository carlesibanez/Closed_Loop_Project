<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro" name="test_gripper">

  <xacro:arg name="ros_namespace" default="" />

   <link name="world"/>

   <!-- <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
